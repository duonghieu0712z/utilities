{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "endOfLine": "lf",
    "ignorePatterns": ["dist/**", "src/generated/**", "src-tauri/gen/**", "src-tauri/target/**"],
    "jsxSingleQuote": true,
    "printWidth": 100,
    "semi": true,
    "singleQuote": true,
    "sortImports": {
        "newlinesBetween": true,
        "groups": [
            "type-import",
            "value-builtin",
            "value-external",
            "value-internal",
            ["value-parent", "value-sibling", "value-index"],
            "style",
            "side_effect",
            "unknown"
        ]
    },
    "sortTailwindcss": {
        "functions": ["clsx", "cn", "cva", "twMerge"]
    },
    "tabWidth": 4,
    "trailingComma": "all",

    "overrides": [
        {
            "files": ["**/*.yml", "**/*.yaml"],
            "options": {
                "tabWidth": 2
            }
        }
    ]
}
