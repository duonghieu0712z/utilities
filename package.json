{
    "name": "kazmas",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "run-p type-check \"build-only {@}\" --",
        "preview": "vite preview",
        "build-only": "vite build",
        "type-check": "vue-tsc --noEmit",
        "start": "pnpm tauri dev",
        "make": "pnpm tauri build",
        "lint": "oxlint .",
        "lint:fix": "oxlint --fix .",
        "format": "oxfmt --check .",
        "format:fix": "oxfmt .",
        "bump": "node bump-version.js",
        "prepare": "husky"
    },
    "dependencies": {
        "@tauri-apps/api": "^2",
        "@tauri-apps/plugin-log": "~2.8.0",
        "@types/node": "^25.6.0",
        "vue": "^3.5.32"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.2",
        "@tauri-apps/cli": "^2",
        "@vitejs/plugin-vue": "^6.0.6",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "npm-run-all2": "^8.0.4",
        "oxfmt": "^0.46.0",
        "oxlint": "^1.61.0",
        "tailwindcss": "^4.2.2",
        "typescript": "~6.0.3",
        "vite": "^8.0.8",
        "vue-tsc": "^3.2.6"
    },
    "lint-staged": {
        "*.{ts,tsx,vue,html,css,json,yaml}": [
            "oxfmt"
        ],
        "*.{ts,tsx,vue}": [
            "oxlint --fix"
        ]
    },
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    }
}
